rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidQuestionRecord(data) {
      return data.userId == request.auth.uid 
        && data.originalText is string && data.originalText.size() < 10000
        && (data.originalImageUrl == null || data.originalImageUrl is string)
        && data.createdAt is timestamp;
    }

    match /questionRecords/{recordId} {
      allow create: if isSignedIn() 
        && isValidQuestionRecord(request.resource.data)
        && request.resource.data.createdAt == request.time;
      
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow update: if isSignedIn() 
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['originalText', 'knowledgePoint', 'variants'])
        );
    }
  }
}
