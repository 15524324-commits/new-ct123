rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return (request.auth != null && request.auth.uid == userId) || userId == 'anonymous';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidQuestionRecord(data) {
      return data.originalText is string && data.originalText.size() < 10000
        && (data.originalImageUrl == null || data.originalImageUrl is string)
        && data.createdAt is timestamp;
    }

    match /questionRecords/{recordId} {
      allow create: if isValidQuestionRecord(request.resource.data);
      
      allow read, write: if true;
    }
  }
}
